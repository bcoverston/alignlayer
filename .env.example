# AlignLayer environment configuration
# Copy to .env and fill in your values

# GitHub username (used in docs and integration references)
GITHUB_USER=bcoverston

# Task output directory for ingest scripts
ALIGNLAYER_TASK_OUTPUT_DIR=/private/tmp/claude-501/tasks

# Deploy target for OpenClaw (scripts/deploy.sh)
ALIGNLAYER_DEPLOY_HOST=your-host
ALIGNLAYER_DEPLOY_PATH=/opt/openclaw
