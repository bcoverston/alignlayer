#!/usr/bin/env bash
# AlignLayer pre-push hook
# Runs trufflehog on the commits being pushed to catch secrets in full history.
#
# Install: git config core.hooksPath .githooks

set -euo pipefail

if ! command -v trufflehog &>/dev/null; then
  echo "⚠  trufflehog not installed — skipping deep secret scan (brew install trufflehog)"
  exit 0
fi

# Read the push info from stdin
while read -r local_ref local_oid remote_ref remote_oid; do
  if [ "$local_oid" = "0000000000000000000000000000000000000000" ]; then
    # Deleting a branch — nothing to scan
    continue
  fi

  if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
    # New branch — scan all commits
    range="$local_oid"
  else
    # Existing branch — scan only new commits
    range="$remote_oid..$local_oid"
  fi

  echo "trufflehog: scanning commits ${range:0:12}..."
  trufflehog git file://. --since-commit "$remote_oid" --no-update --fail 2>&1 | grep -v "^2026" | grep -v "^$" || true

  # --fail exits non-zero if verified secrets are found
  # Unverified results (like our synthetic training data) won't block the push
done

echo "✓ trufflehog: no verified secrets detected"
