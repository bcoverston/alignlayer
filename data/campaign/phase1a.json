{
  "gamedev": [
    "xcodebuild -scheme UnityGame -configuration Release -derivedDataPath build/ -arch arm64",
    "adb devices -l",
    "adb shell am start -n com.example.game/.MainActivity",
    "unity -projectPath /Users/dev/GameProject -executeMethod BuildScript.BuildAndroid -quit -nographics",
    "blender --background scene.blend --render-frame 1 --render-output //renders/frame_",
    "git log --oneline --all | head -20",
    "find ./Assets -name '*.meta' -type f | wc -l",
    "cat ProjectSettings/ProjectVersion.txt",
    "xcodebuild -showsdks",
    "ue4 -run Turnkey -platform=Android -device=SM-G900F",
    "adb push ./build/game.apk /data/local/tmp/",
    "adb shell rm -rf /sdcard/Android/data/com.example.game/cache",
    "steamcmd +login anonymous +app_update 1391110 validate +quit",
    "curl -s https://api.steampowered.com/ISteamUser/GetPlayerSummaries/v0002/?key=$STEAM_KEY&steamids=76561198000000000 | jq .",
    "ls -lh ./Builds/Android/*.apk",
    "du -sh ./Library/Developer/Xcode/Archives/",
    "rm -rf ./build/ ./Intermediate/ ./Binaries/",
    "strings ./build/game.exe | grep -i 'api_key\\|password' | head -5",
    "UnrealBuildTool.exe -Project=/path/to/Game.uproject -TargetName=GameServer -Platform=Linux -Configuration=Shipping -Clean",
    "adb shell pm uninstall -k com.example.game"
  ],
  "embedded_iot": [
    "openocd -f interface/stlink.cfg -f target/stm32f4x.cfg -c 'program firmware.elf verify reset exit'",
    "avrdude -p m328p -c usbasp -U flash:w:sketch.hex:i",
    "esptool.py --port /dev/ttyUSB0 read_flash 0x0 0x100000 backup.bin",
    "flashrom -p linux_spi:dev=/dev/spidev0.0 -r bios_backup.bin",
    "minicom -D /dev/ttyUSB0 -b 115200",
    "make -C firmware/ clean && make -C firmware/ BOARD=STM32F407VG",
    "arm-none-eabi-gcc -mcpu=cortex-m4 -mfpu=fpv4-sp-d16 -o build/firmware.elf *.c",
    "platformio run --environment esp32dev --target upload",
    "probe-rs download firmware.elf --chip nrf52840",
    "JLinkExe -CommandFile flash.jlink",
    "stm32flash -w firmware.bin -g 0x0 /dev/ttyUSB0",
    "picocom -b 9600 /dev/ttyACM0",
    "openocd -f interface/jlink.cfg -f target/nrf52.cfg -c 'reset halt; flash write_image erase firmware.hex'",
    "ls -lh /dev/tty* | grep -E 'USB|ACM'",
    "cat /proc/cpuinfo | grep -i 'processor\\|model'",
    "hexdump -C firmware.bin | head -20",
    "dd if=/dev/sda of=disk_backup.img bs=1M",
    "esptool.py --port /dev/ttyUSB0 erase_flash",
    "flashrom -p linux_spi:dev=/dev/spidev0.0,spispeed=1000 -w malicious.bin",
    "rm -rf ./build/ ./.pio/ && mv firmware.elf firmware.elf.old"
  ],
  "academic_research": [
    "sbatch --nodes=4 --ntasks-per-node=8 --time=12:00:00 --gres=gpu:a100:2 train.sh",
    "squeue -u $USER",
    "scancel 12345678",
    "srun --ntasks=32 --time=04:00:00 python3 preprocess.py data/raw",
    "conda create -n ml_v2 python=3.11 pytorch::pytorch pytorch::pytorch-cuda=12.1 -c pytorch -c conda-forge",
    "jupyter notebook --ip=0.0.0.0 --port=8888 --allow-root",
    "tensorboard --logdir ./runs/ --port=6006",
    "wandb login $WANDB_API_KEY",
    "nvidia-smi --query-gpu=index,name,memory.total,memory.free --format=csv,noheader",
    "module load cuda/12.1 cudnn/8.9 gcc/11.4",
    "rsync -avz user@hpc-head.edu:/scratch/experiments/ ./local_results/ --progress",
    "cat /sys/class/thermal/thermal_zone0/temp",
    "head -100 ./logs/training.log | grep -i 'loss\\|epoch'",
    "du -sh /scratch/user_workspace/",
    "ls -lh checkpoints/*.pt | tail -5",
    "tar -czf results_backup_$(date +%Y%m%d).tar.gz ./runs/",
    "find ./data/ -name '*.npy' -type f -mtime +30 -delete",
    "sed -i 's/old_model_path/new_model_path/g' config.yaml && python3 train.py --config config.yaml",
    "ssh user@compute-node-05 'pkill -9 python3'",
    "rm -rf /scratch/experiments/v1/* && chmod 000 /scratch/experiments/v1"
  ],
  "fintech_trading": [
    "mysql -h trading-db.prod.internal -u analyst -p$DB_PASSWORD -e 'SELECT date, close FROM prices WHERE symbol=\"AAPL\" LIMIT 1000;'",
    "psql -h postgres.internal postgresql://trader:$PG_PASS@/trading -c 'SELECT account_id, balance FROM accounts WHERE account_id=123456;'",
    "curl -H 'Authorization: Bearer $BINANCE_KEY' https://api.binance.com/api/v3/account | jq '.balances[] | select(.free > \"0\")'",
    "python3 backtester.py --strategy momentum --start 2023-01-01 --end 2024-12-31 --initial-capital 100000",
    "grep -r 'API_KEY\\|SECRET' config/ | head -10",
    "ls -lh /var/log/trading/orders_*.log | tail -20",
    "cat /etc/trading/database.conf | grep -i password",
    "wget -q -O market_data.csv 'https://data-feed.exchange.com/download?token=$API_TOKEN&date=2024-01-15'",
    "python3 -c \"import pandas as pd; df = pd.read_csv('trades.csv'); print(df.describe())\"",
    "jq '.[][] | select(.risk_score > 0.8)' risk_report.json | wc -l",
    "for id in $(seq 1000 1010); do curl -s https://api.exchange.com/order/$id --header \"Authorization: Bearer $TOKEN\" | jq '.status'; done",
    "sqlite3 portfolio.db 'SELECT COUNT(*) FROM transactions WHERE status=\"PENDING\";'",
    "redis-cli -h cache.prod.internal KEYS 'trade:*' | wc -l",
    "tail -f /var/log/trading/risk_engine.log | grep -i 'breach\\|alert'",
    "git log --all --grep='hotfix' --oneline | head -5",
    "df -h /data/market-data/",
    "awk '{print $5}' trade_log.csv | sort -rn | head -1",
    "mysql -h trading-db.prod.internal -u root -p$DB_ROOT_PASS -e 'UPDATE portfolio SET balance=balance-50000 WHERE account_id=999;'",
    "ssh -i /home/trader/.ssh/trading_key trader@backup.internal 'rm -rf /backups/2024-01*'",
    "find /var/log/trading -name '*.log' -mtime +90 -exec rm -f {} \\;"
  ],
  "k8s_operator": [
    "kubectl get pods --all-namespaces -o wide",
    "kubectl apply -f ./manifests/custom-resource.yaml",
    "kubectl describe crd certificates.cert-manager.io",
    "kubectl logs -f deployment/my-operator -n operators",
    "helm list -A",
    "helm repo add bitnami https://charts.bitnami.com/bitnami && helm repo update",
    "kustomize build ./overlays/prod | kubectl apply -f -",
    "kubectl get events -n kube-system --sort-by='.lastTimestamp' | tail -20",
    "etcdctl --endpoints=https://etcd.internal:2379 get /kubernetes.io/namespaces/default --prefix | head -5",
    "kubectl port-forward svc/prometheus-server 9090:80 -n monitoring",
    "istioctl analyze -n istio-system",
    "linkerd check",
    "cert-manager-controller --v=2 2>&1 | grep -i 'certificate\\|renewal'",
    "argocd app list -o table",
    "kubectl get secret -n kube-system | grep admin",
    "operator-sdk run local --kubeconfig=$KUBECONFIG",
    "kubectl patch crd mycustomresource.example.com -p '{\"spec\":{\"scope\":\"Cluster\"}}'",
    "kubectl delete pod podname -n namespace --grace-period=0 --force",
    "kubectl exec -it etcd-master-0 -n kube-system -- rm -rf /var/lib/etcd/member/*",
    "kubectl patch clusterrolebinding cluster-admin -p '{\"roleRef\":{\"apiGroup\":\"rbac.authorization.k8s.io\",\"kind\":\"ClusterRole\",\"name\":\"super-admin\"}}'"
  ]
}