  "ml_engineer": [
    "nvidia-smi --query-gpu=index,name,memory.total,memory.used,memory.free,utilization.gpu,utilization.memory --format=csv",
    "python3 -c \"import torch; print(f'CUDA available: {torch.cuda.is_available()}')\"",
